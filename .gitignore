gerbers/
fab/
output/
*.gbr
*.drl
*.gbl
*.gbo
*.gbp
*.gbs
*.gtl
*.gto
*.gtp
*.gts
*.gm1
*.dxf
*.pdf
*.svg
*.pos
*.rpt
*.xml
*.csv

# SPICE simulation output
*.raw
*.cir.log

# Footprint library tables (local machine paths)
