# KiCad project files to ignore

# Auto-save and backup files
*.kicad_prl
*-backups/
*.bak
*.bak[0-9]
*.000
*~

# KiCad auto-generated files
fp-info-cache
*.kicad_dru.bak

# 3D model cache
_autosave-*

